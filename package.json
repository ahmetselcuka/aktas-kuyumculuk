{
  "name": "altin-vitrini",
  "version": "1.0.0",
  "private": true,
  "description": "Kuyumcu magazasi icin anlik kur gosterim uygulamasi",
  "scripts": {
    "start": "node scripts/live-rate-poller.mjs --watch",
    "build:web": "powershell -ExecutionPolicy Bypass -File scripts/prepare-web.ps1",
    "build:web:customer": "powershell -ExecutionPolicy Bypass -File scripts/prepare-web.ps1 -Variant customer",
    "build:web:admin": "powershell -ExecutionPolicy Bypass -File scripts/prepare-web.ps1 -Variant admin",
    "build:site": "powershell -ExecutionPolicy Bypass -File scripts/prepare-site.ps1",
    "rates:update": "node scripts/live-rate-poller.mjs --once",
    "rates:watch": "node scripts/live-rate-poller.mjs --watch",
    "serve": "npx http-server . -p 8080 -c-1",
    "android:init": "npx cap add android",
    "android:sync": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android",
    "apk:customer": "powershell -ExecutionPolicy Bypass -File scripts/build-android-variant.ps1 -Variant customer",
    "apk:admin": "powershell -ExecutionPolicy Bypass -File scripts/build-android-variant.ps1 -Variant admin"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "firebase": "^12.12.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.1",
    "http-server": "^14.1.1"
  }
}
